FROM keycloak/keycloak:25.0

# The realm JSON is prepared by deploy.sh on the deploy machine (python3 available there)
# and uploaded as keycloak-realm-prepared.json — no python3 needed here.
COPY ./docker/keycloak-realm-prepared.json /etc/keycloak/realm.json
COPY ./docker/keycloak-entrypoint.sh /usr/local/bin/entrypoint.sh

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]

CMD ["start", "--import-realm"]
