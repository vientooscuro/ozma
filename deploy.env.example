# Deploy configuration
# Copy this file to deploy.env and fill in the values:
#   cp deploy.env.example deploy.env

# SSH target for remote deploy (user@host)
DEPLOY_HOST=

# Server domain (used for Caddy, Keycloak, EXTERNAL_ORIGIN)
DOMAIN=

# Keycloak admin user (realm: master)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ozma application user (realm: ozma + ozma DB)
OZMA_USER_EMAIL=
OZMA_USER_PASSWORD=

# Optional: client secret for the ozmadb Keycloak client
# If not set, the default secret from keycloak-realm.json is used
OZMADB_CLIENT_SECRET=
